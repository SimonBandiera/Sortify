#!/bin/bash

# Sortify Docker Deployment Script (with existing nginx)
# Domain: sortify.fr
# Usage: ./run.sh [start|stop|restart|build|logs|update|help]

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
COMPOSE_FILE="docker-compose.yml"
PROJECT_NAME="sortify"
DOMAIN="sortify.fr"
# File used for ${VAR} interpolation in docker-compose.yml (e.g. SPOTIFY_CLIENT_ID).
# Note: this is separate from the per-service `env_file:` key.
ENV_FILE="./backend/.env"

# Functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if Docker is running
check_docker() {
    if ! docker info > /dev/null 2>&1; then
        log_error "Docker is not running. Please start Docker and try again."
        exit 1
    fi
}

# Start all services
start_services() {
    log_info "Starting frontend and backend containers..."
    docker compose -f $COMPOSE_FILE -p $PROJECT_NAME --env-file $ENV_FILE up -d
    log_success "Containers started!"
    log_info "Frontend: http://localhost:3000"
    log_info "Backend: http://localhost:8000"
    log_info "Access via nginx: https://$DOMAIN"
}

# Stop all services
stop_services() {
    log_info "Stopping containers..."
    docker compose -f $COMPOSE_FILE -p $PROJECT_NAME --env-file $ENV_FILE down
    log_success "Containers stopped!"
}

# Restart all services
restart_services() {
    log_info "Restarting containers..."
    docker compose -f $COMPOSE_FILE -p $PROJECT_NAME --env-file $ENV_FILE restart
    log_success "Containers restarted!"
}

# Build all images
build_images() {
    log_info "Building Docker images..."
    docker compose -f $COMPOSE_FILE -p $PROJECT_NAME --env-file $ENV_FILE build --no-cache
    log_success "Images built!"
}

# Show logs
show_logs() {
    log_info "Showing logs for all services..."
    docker compose -f $COMPOSE_FILE -p $PROJECT_NAME --env-file $ENV_FILE logs -f
}

# Update application (pull and redeploy)
update_app() {
    log_info "Updating application..."

    # Pull latest changes
    git pull

    # Rebuild and restart
    build_images
    restart_services

    log_success "Application updated!"
}

# Check status
status() {
    log_info "Checking service status..."
    docker compose -f $COMPOSE_FILE -p $PROJECT_NAME --env-file $ENV_FILE ps
}

# Show help
show_help() {
    cat << EOF
${BLUE}Sortify Docker Deployment Script (with existing nginx)${NC}

Usage: $0 [command]

Commands:
  start       - Start frontend and backend containers
  stop        - Stop all containers
  restart     - Restart all containers
  build       - Build Docker images
  logs        - Show logs for all services
  update      - Pull latest changes and redeploy
  status      - Show service status
  help        - Show this help message

Setup:
  1. Update /etc/nginx/sites-enabled/sortify to proxy to localhost:3000 and localhost:8000
  2. Run: sudo nginx -t && sudo systemctl reload nginx
  3. Run: $0 start

Your existing nginx (port 80/443) will proxy to:
  - Frontend: localhost:3000
  - Backend:  localhost:8000

Domain: $DOMAIN
EOF
}

# Main script logic
case "$1" in
    start)
        check_docker
        start_services
        ;;
    stop)
        check_docker
        stop_services
        ;;
    restart)
        check_docker
        restart_services
        ;;
    build)
        check_docker
        build_images
        ;;
    logs)
        check_docker
        show_logs
        ;;
    update)
        check_docker
        update_app
        ;;
    status)
        check_docker
        status
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac